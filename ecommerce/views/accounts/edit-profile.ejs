<% layout('layout') -%>
<div class="row">
<div class="col-lg-6 col-lg-offset-3">


<% if (message.length > 0) { %>
  <div class="alert alert-danger alert-dismissible">
    <button type="button" class="close" data-dismiss="alert" arial-label="close">
      <span aral-hidden="true">&times;</span>
      <%= message %>
    </button>

  </div>
<% } %>
<form class="form-horizontal" action='' method="POST">
    <fieldset>
      <div id="legend">
        <legend class="">Edit Profile</legend>
      </div>
   
      <div class="control-group">
        <!-- name -->
        <label class="control-label" for="name">name </label>
        <div class="controls">
          <input type="text" id="name" name="name" placeholder="" value="<%= user.profile.name %>" class="input-xlarge">
        </div>
      </div>
      
   
      <div class="control-group">
        <!-- address-->
        <label class="control-label" for="address">Address</label>
        <div class="controls">
          <input type="text" id="address" name="address" placeholder="" value="<%= user.profile.address %>" class="input-xlarge">
        </div>
      </div>

      <div class="control-group">
        <!-- Button -->
        <div class="controls">
          <button type="submit" class="btn btn-success">Save</button>
        </div>
      </div>
    </fieldset>
  </form>
</div>
</div>