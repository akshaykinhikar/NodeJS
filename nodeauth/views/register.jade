extends layout
block content
	.container
		h1 register
		h3 Plz register
		form(method='post', action='/user/register', enctype='multipart/form-data')
			.form-group
				label name
				input.form-control(name='name', type='text', placeholder='name')
			.form-group
				label Email
				input.form-control(name='name', type='text', placeholder='Email')
			.form-group
				label userName
				input.form-control(name='name', type='text', placeholder='userName')
			.form-group
				label Password
				input.form-control(name='password', type='text', placeholder='Password')
			.form-group
				label Password
				input.form-control(name='password2', type='text', placeholder='Password')
			.form-group
				label profile Image
				input.form-control(name='profileImge', type='file')
			input.btn.btn-default(name='submit', type='submit', value='register')